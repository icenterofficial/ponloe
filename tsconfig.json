{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src",
    "src/components",
    "src/hooks",
    "src/lib",
    "src/services",
    "src/contexts",
    "types.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "server.ts",
    "test.ts",
    "test2.ts",
    "test.js",
    "supabase"
  ]
}
